{
  "name": "mirofish-mcp",
  "version": "0.1.0",
  "description": "MCP server for MiroFish swarm simulation platform",
  "license": "AGPL-3.0-only",
  "type": "module",
  "bin": {
    "mirofish-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:stdio": "TRANSPORT=stdio node dist/index.js",
    "start:http": "TRANSPORT=http node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.7.0",
    "express": "^5.2.0",
    "form-data": "^4.0.5",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
